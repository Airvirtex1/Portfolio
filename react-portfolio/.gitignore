*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# ── Test / coverage ───────────────────────────────────────────────
coverage/
.nyc_output/

# ── Cache ─────────────────────────────────────────────────────────
.cache/
.vite/
*.local

# ── OS artifacts ─────────────────────────────────────────────────
